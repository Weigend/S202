<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.SVGPath?>

<HBox fx:id="nodeBox" spacing="8" styleClass="node-box" 
    xmlns="http://javafx.com/javafx" 
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="de.weigend.s202.ui.newlayout.NodeComponentController">
    <padding>
        <Insets top="6" right="10" bottom="6" left="10"/>
    </padding>

    <!-- Icon (disclosure control for packages, or type icon for classes) -->
    <StackPane fx:id="iconContainer" minWidth="20" maxWidth="20" minHeight="20" maxHeight="20">
        <HBox fx:id="disclosureControl" styleClass="disclosure-control">
            <!-- Will be filled by controller: + or - -->
        </HBox>
    </StackPane>

    <!-- Node Label -->
    <Label fx:id="nodeLabel" text="NodeName" styleClass="node-label"/>

    <!-- Optional marker (e.g. asterisk for cyclic dependencies) -->
    <Label fx:id="markerLabel" text="" styleClass="node-marker" />
</HBox>
